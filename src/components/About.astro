---
// About — section label, three body paragraphs, currently-building callout
import { frontmatter, Content } from '../../content/about.md';
const { calloutLabel, calloutItems } = frontmatter;
---

<section id="about">
  <p class="section-label">01 / About</p>

  <div class="prose">
    <Content />
  </div>

  <div class="callout">
    <p class="callout-label">{calloutLabel}</p>
    <p class="callout-prose">
      {calloutItems.map((item: { name: string; description: string }, i: number) => (
        <>
          <code>{item.name}</code>{`, ${item.description}`}{i < calloutItems.length - 1 ? ' · ' : ''}
        </>
      ))}
    </p>
  </div>
</section>

<style>
  #about {
    padding-top: clamp(4rem, 8vw, 6rem);
    padding-bottom: clamp(3rem, 8vw, 5rem);
  }

  .section-label {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .prose :global(p) {
    font-family: var(--serif);
    font-optical-sizing: auto;
    font-size: clamp(0.95rem, 1.4vw, 1.05rem);
    line-height: 1.75;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  .callout {
    margin-top: 2rem;
    border-left: 2px solid var(--accent);
    padding: 0.9rem 1.25rem;
    background: var(--bg-subtle);
    border-radius: 0 3px 3px 0;
  }

  .callout-label {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.55rem;
  }

  .callout-prose {
    font-family: var(--serif);
    font-size: clamp(0.9rem, 1.3vw, 1rem);
    line-height: 1.5;
    color: var(--text);
  }

  .callout-prose code {
    font-family: var(--mono);
    font-size: 0.82em;
    background: var(--bg-card);
    color: var(--text);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    border: 1px solid var(--border);
  }
</style>
