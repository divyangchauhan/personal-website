---
// Hero — name, tagline, description, CTAs
import { frontmatter, compiledContent } from '../../content/hero.md';
const { name, tagline, ctaPrimary, ctaSecondary } = frontmatter;
const descriptionHtml = compiledContent();
---

<section id="hero">
  <h1 class="name">{name}</h1>
  <p class="tagline">{tagline}</p>
  <div class="description" set:html={descriptionHtml} />
  <div class="ctas">
    <a href={ctaPrimary.href} class="btn-primary">{ctaPrimary.label}</a>
    <a href={ctaSecondary.href} class="btn-secondary">{ctaSecondary.label}</a>
  </div>
</section>

<style>
  #hero {
    padding-block: clamp(4.5rem, 12vw, 7rem) clamp(3rem, 8vw, 5rem);
  }

  .name {
    font-family: var(--display);
    font-weight: 700;
    font-optical-sizing: auto;
    font-size: clamp(2.25rem, 6vw, 4rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .tagline {
    font-family: var(--display);
    font-weight: 300;
    font-style: italic;
    font-optical-sizing: auto;
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    line-height: 1.5;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .description {
    font-family: 'Source Serif 4', Georgia, serif;
    font-optical-sizing: auto;
    font-size: clamp(0.95rem, 1.4vw, 1.05rem);
    line-height: 1.55;
    letter-spacing: -0.005em;
    color: var(--text-body);
    margin-bottom: 2.75rem;
  }

  .description :global(strong) {
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: var(--text-muted);
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }

  .ctas {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
    background: var(--accent);
    color: #111010;
    font-family: var(--mono);
    font-size: 0.85rem;
    padding: 0.65rem 1.5rem;
    border-radius: 4px;
    text-decoration: none;
    transition: background 175ms ease-out;
  }

  .btn-primary:hover {
    background: #ff9a56;
  }

  .btn-secondary {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid var(--text);
    padding-bottom: 2px;
    transition: color 175ms ease-out, border-color 175ms ease-out;
  }

  .btn-secondary:hover {
    color: var(--text-muted);
    border-color: var(--text-muted);
  }
</style>
