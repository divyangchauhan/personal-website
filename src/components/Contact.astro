---
// Contact — section label + email, GitHub, LinkedIn, resume rows
import { frontmatter } from '../../content/contact.md';
const { intro, rows } = frontmatter;
---

<section id="contact">
  <p class="section-label">04 / Contact</p>

  <p class="intro">{intro}</p>

  <div class="contact-rows">
    {rows.map((row: { service: string; display: string; href: string; external: boolean; download: boolean; arrow: string }) => (
      <a
        class="contact-row"
        href={row.href}
        target={row.external ? '_blank' : undefined}
        rel={row.external ? 'noopener noreferrer' : undefined}
        download={row.download || undefined}
        aria-label={`${row.service}: ${row.display}`}
      >
        <span class="service">{row.service.toUpperCase()}</span>
        <span class="display">{row.display}</span>
        <span class="arrow" aria-hidden="true">{row.arrow}</span>
      </a>
    ))}
  </div>
</section>

<style>
  #contact {
    padding-top: clamp(4rem, 8vw, 6rem);
    padding-bottom: clamp(3rem, 8vw, 5rem);
  }

  .section-label {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .intro {
    font-family: var(--serif);
    font-size: clamp(0.95rem, 1.4vw, 1.05rem);
    line-height: 1.75;
    color: var(--text);
    margin-bottom: 2rem;
  }

  .contact-rows {
    display: flex;
    flex-direction: column;
  }

  .contact-row {
    display: grid;
    grid-template-columns: 7rem 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 0.75rem;
    margin: 0 -0.75rem;
    border-radius: 4px;
    text-decoration: none;
    transition: background 160ms ease-out, color 160ms ease-out;
  }

  .contact-row:hover,
  .contact-row:focus-visible {
    background: var(--accent-dim);
    outline: none;
  }

  .contact-row:focus-visible {
    box-shadow: 0 0 0 2px var(--accent);
  }

  .service {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    transition: color 160ms ease-out;
  }

  .contact-row:hover .service,
  .contact-row:focus-visible .service {
    color: var(--accent);
  }

  .display {
    font-family: var(--serif);
    font-size: clamp(0.9rem, 1.3vw, 1rem);
    color: var(--text);
  }

  .arrow {
    font-family: var(--mono);
    color: var(--text-muted);
    transition: transform 160ms ease-out, color 160ms ease-out;
  }

  .contact-row:hover .arrow,
  .contact-row:focus-visible .arrow {
    transform: translateX(4px);
    color: var(--accent);
  }

  @media (max-width: 520px) {
    .contact-row {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
    }

    .service {
      grid-column: 1;
      grid-row: 1;
      font-size: 0.65rem;
      margin-bottom: 0.1rem;
    }

    .display {
      grid-column: 1;
      grid-row: 2;
      font-size: 0.9rem;
    }

    .arrow {
      grid-column: 2;
      grid-row: 1 / 3;
      align-self: center;
    }
  }
</style>
